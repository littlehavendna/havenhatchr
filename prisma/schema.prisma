generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BirdSex {
  Male
  Female
  Unknown
}

enum BirdStatus {
  Active
  Holdback
  Retired
  Sold
}

enum ChickStatus {
  Available
  Reserved
  Sold
  Holdback
}

enum ReservationStatus {
  Waiting
  Matched
  Completed
  Cancelled
}

enum DnaTestStatus {
  Pending
  Completed
  Cancelled
}

enum NoteEntityType {
  bird
  flock
  customer
  pairing
  hatchGroup
  chick
  order
  reservation
}

enum PhotoEntityType {
  bird
  chick
  flock
  hatchGroup
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  plan         String        @default("starter")
  stripeCustomerId      String?        @unique
  stripeSubscriptionId  String?        @unique
  subscriptionStatus    String         @default("inactive")
  trialEnd              DateTime?
  currentPeriodEnd      DateTime?
  isBetaUser            Boolean        @default(false)
  isAdmin               Boolean        @default(false)
  isFounder             Boolean        @default(false)
  aiAccessEnabled       Boolean        @default(true)
  hasCompletedTutorial  Boolean        @default(false)
  hasSkippedTutorial    Boolean        @default(false)
  tutorialCompletedAt   DateTime?
  lastLoginAt           DateTime?
  accountDisabledAt     DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  sessions              Session[]
  customers             Customer[]
  flocks                Flock[]
  birds                 Bird[]
  pairings              Pairing[]
  hatchGroups           HatchGroup[]
  chicks                Chick[]
  reservations          Reservation[]
  orders                Order[]
  traits                Trait[]
  notes                 Note[]
  photos                Photo[]
  createdFeatureFlags   FeatureFlag[]  @relation("FeatureFlagCreatedBy")
  updatedFeatureFlags   FeatureFlag[]  @relation("FeatureFlagUpdatedBy")
  auditLogs             AuditLog[]     @relation("AuditActor")
  subjectAuditLogs      AuditLog[]     @relation("AuditSubjectUser")
  updatedSystemSettings SystemSetting[]
  usageEvents           UsageEvent[]
  aiUsageLogs           AiUsageLog[]
  dnaTestRequests       DnaTestRequest[]
  operationalEvents     OperationalEvent[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id           String        @id @default(cuid())
  userId       String
  name         String
  email        String        @default("")
  phone        String        @default("")
  location     String        @default("")
  notes        String        @default("")
  status       String        @default("Active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  orders       Order[]
  noteEntries  Note[]        @relation("CustomerNotes")

  @@index([userId])
}

model Flock {
  id           String   @id @default(cuid())
  userId       String
  name         String
  breed        String   @default("")
  variety      String   @default("")
  notes        String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birds        Bird[]
  chicks       Chick[]
  noteEntries  Note[]   @relation("FlockNotes")
  photoEntries Photo[]  @relation("FlockPhotos")

  @@index([userId])
}

model Bird {
  id            String     @id @default(cuid())
  userId        String
  name          String
  bandNumber    String
  sex           BirdSex
  breed         String     @default("")
  variety       String     @default("")
  color         String     @default("")
  genetics      String     @default("")
  flockId       String
  status        BirdStatus
  notes         String     @default("")
  photoUrl      String     @default("")
  visualTraits  String[]   @default([])
  carriedTraits String[]   @default([])
  genotypeNotes String     @default("")
  projectTags   String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  flock         Flock      @relation(fields: [flockId], references: [id], onDelete: Cascade)
  sirePairings  Pairing[]  @relation("PairingSire")
  damPairings   Pairing[]  @relation("PairingDam")
  traits        Trait[]
  noteEntries   Note[]     @relation("BirdNotes")
  photoEntries  Photo[]    @relation("BirdPhotos")

  @@index([userId])
  @@unique([userId, bandNumber])
}

model Pairing {
  id           String      @id @default(cuid())
  userId       String
  name         String
  sireId       String
  damId        String
  goals        String      @default("")
  targetTraits String[]    @default([])
  avoidTraits  String[]    @default([])
  projectGoal  String      @default("")
  notes        String      @default("")
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sire         Bird        @relation("PairingSire", fields: [sireId], references: [id], onDelete: Cascade)
  dam          Bird        @relation("PairingDam", fields: [damId], references: [id], onDelete: Cascade)
  hatchGroups  HatchGroup[]
  noteEntries  Note[]      @relation("PairingNotes")
  photoEntries Photo[]     @relation("PairingPhotos")

  @@index([userId])
}

model HatchGroup {
  id                    String     @id @default(cuid())
  userId                String
  name                  String
  pairingId             String
  breedDesignation      String     @default("Chicken")
  setDate               DateTime
  lockdownDate          DateTime
  hatchDate             DateTime
  eggsSet               Int        @default(0)
  eggsHatched           Int        @default(0)
  producedTraitsSummary String     @default("")
  notes                 String     @default("")
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pairing               Pairing    @relation(fields: [pairingId], references: [id], onDelete: Cascade)
  chicks                Chick[]
  noteEntries           Note[]     @relation("HatchGroupNotes")
  photoEntries          Photo[]    @relation("HatchGroupPhotos")

  @@index([userId])
}

model Chick {
  id             String      @id @default(cuid())
  userId         String
  bandNumber     String
  hatchDate      DateTime
  flockId        String
  hatchGroupId   String?
  status         ChickStatus
  sex            BirdSex
  color          String      @default("")
  observedTraits String[]    @default([])
  notes          String      @default("")
  photoUrl       String      @default("")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flock          Flock       @relation(fields: [flockId], references: [id], onDelete: Cascade)
  hatchGroup     HatchGroup? @relation(fields: [hatchGroupId], references: [id], onDelete: SetNull)
  noteEntries    Note[]      @relation("ChickNotes")
  photoEntries   Photo[]     @relation("ChickPhotos")
  orderItems     OrderChick[]
  dnaTestRequests DnaTestRequest[]

  @@index([userId])
  @@unique([userId, bandNumber])
}

model DnaTestRequest {
  id                String        @id @default(cuid())
  userId            String
  chickId           String
  bandNumber        String
  testType          String
  status            DnaTestStatus @default(Pending)
  externalOrderId   String?       @default("")
  resultSummary     String?       @default("")
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chick             Chick         @relation(fields: [chickId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chickId])
  @@index([status])
}

model Reservation {
  id               String            @id @default(cuid())
  userId           String
  customerId       String
  requestedSex     String            @default("No Preference")
  requestedBreed   String            @default("")
  requestedVariety String            @default("")
  requestedColor   String            @default("")
  quantity         Int
  status           ReservationStatus
  notes            String            @default("")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  noteEntries      Note[]            @relation("ReservationNotes")

  @@index([userId])
}

model Order {
  id          String       @id @default(cuid())
  userId      String
  customerId  String
  total       Float        @default(0)
  status      String       @default("Pending")
  pickupDate  DateTime
  notes       String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  noteEntries Note[]       @relation("OrderNotes")
  orderChicks OrderChick[]

  @@index([userId])
}

model OrderChick {
  orderId    String
  chickId    String
  assignedAt DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  chick      Chick    @relation(fields: [chickId], references: [id], onDelete: Cascade)

  @@id([orderId, chickId])
  @@index([chickId])
}

model Trait {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String   @default("")
  description String   @default("")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birds       Bird[]

  @@index([userId])
  @@unique([userId, name])
}

model Note {
  id            String           @id @default(cuid())
  userId        String
  entityType    NoteEntityType
  entityId      String
  content       String
  birdId        String?
  chickId       String?
  pairingId     String?
  hatchGroupId  String?
  flockId       String?
  customerId    String?
  orderId       String?
  reservationId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bird          Bird?            @relation("BirdNotes", fields: [birdId], references: [id], onDelete: SetNull)
  chick         Chick?           @relation("ChickNotes", fields: [chickId], references: [id], onDelete: SetNull)
  pairing       Pairing?         @relation("PairingNotes", fields: [pairingId], references: [id], onDelete: SetNull)
  hatchGroup    HatchGroup?      @relation("HatchGroupNotes", fields: [hatchGroupId], references: [id], onDelete: SetNull)
  flock         Flock?           @relation("FlockNotes", fields: [flockId], references: [id], onDelete: SetNull)
  customer      Customer?        @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: SetNull)
  order         Order?           @relation("OrderNotes", fields: [orderId], references: [id], onDelete: SetNull)
  reservation   Reservation?     @relation("ReservationNotes", fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([birdId])
  @@index([chickId])
  @@index([pairingId])
  @@index([hatchGroupId])
  @@index([flockId])
  @@index([customerId])
  @@index([orderId])
  @@index([reservationId])
}

model Photo {
  id           String          @id @default(cuid())
  userId       String
  entityType   PhotoEntityType
  entityId     String
  url          String
  caption      String
  birdId       String?
  chickId      String?
  pairingId    String?
  hatchGroupId String?
  flockId      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bird         Bird?           @relation("BirdPhotos", fields: [birdId], references: [id], onDelete: SetNull)
  chick        Chick?          @relation("ChickPhotos", fields: [chickId], references: [id], onDelete: SetNull)
  pairing      Pairing?        @relation("PairingPhotos", fields: [pairingId], references: [id], onDelete: SetNull)
  hatchGroup   HatchGroup?     @relation("HatchGroupPhotos", fields: [hatchGroupId], references: [id], onDelete: SetNull)
  flock        Flock?          @relation("FlockPhotos", fields: [flockId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([birdId])
  @@index([chickId])
  @@index([pairingId])
  @@index([hatchGroupId])
  @@index([flockId])
}

model FeatureFlag {
  id             String   @id @default(cuid())
  name           String
  key            String   @unique
  description    String   @default("")
  enabled        Boolean  @default(false)
  rolloutPercent Int?
  audience       String   @default("all")
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User?    @relation("FeatureFlagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?    @relation("FeatureFlagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([enabled])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  subjectUserId String?
  action        String
  entityType    String
  entityId      String?
  summary       String
  metadata      Json?
  createdAt     DateTime @default(now())
  actorUser     User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subjectUser   User?    @relation("AuditSubjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([subjectUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String   @default("")
  value       Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

model UsageEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  route      String   @default("")
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model AiUsageLog {
  id            String   @id @default(cuid())
  userId        String?
  tool          String
  action        String   @default("")
  inputSummary  String   @default("")
  outputSummary String   @default("")
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tool])
  @@index([createdAt])
}

model OperationalEvent {
  id        String   @id @default(cuid())
  userId    String?
  level     String
  source    String
  eventType String
  message   String
  route     String   @default("")
  requestId String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([level])
  @@index([source])
  @@index([eventType])
  @@index([requestId])
  @@index([createdAt])
}
